import requests
import time
import logging
import os

from datetime import datetime
from concurrent.futures import ThreadPoolExecutor

TARGETS = [
    "http://127.0.0.1:8080"
]

REQUEST_DELAY = 1.0
MAX_THREADS = 5
TIMEOUT = 10

os.makedirs("logs", exist_ok=True)
os.makedirs("reports", exist_ok=True)

logging.basicConfig(
    filename="logs/scan.log",
    level=logging.INFO,
    format="%(asctime)s - %(levelname)s - %(message)s"
)

def log(message):
    print(message)
    logging.info(message)

results = []

def check_security_headers(response, url):
    required_headers = [
        "Content-Security-Policy",
        "X-Frame-Options",
        "X-Content-Type-Options"
    ]

    for header in required_headers:
        if header not in response.headers:
            finding = f"[WARNING] {url} missing security header: {header}"
            log(finding)
            results.append(finding)

def scan_url(url):
    try:
        log(f"[+] Visiting {url}")

        response = requests.get(
            url,
            timeout=TIMEOUT
        )

        result = (
            f"{url} | "
            f"Status={response.status_code} | "
            f"Length={len(response.text)}"
        )

        log(result)
        results.append(result)

        check_security_headers(response, url)

        time.sleep(REQUEST_DELAY)

    except Exception as e:
        error = f"{url} | ERROR: {e}"
        log(error)
        results.append(error)

def save_report():
    filename = (
        "reports/report_" +
        datetime.now().strftime("%Y%m%d_%H%M%S") +
        ".txt"
    )

    with open(filename, "w") as f:
        f.write("WEB ASSESSMENT REPORT\n")
        f.write("=" * 50 + "\n\n")

        for item in results:
            f.write(item + "\n")

    return filename

def main():
    log("[*] Starting scan")

    with ThreadPoolExecutor(max_workers=MAX_THREADS) as executor:
        executor.map(scan_url, TARGETS)

    report = save_report()
    log(f"[+] Report saved: {report}")

if __name__ == "__main__":
    main()
