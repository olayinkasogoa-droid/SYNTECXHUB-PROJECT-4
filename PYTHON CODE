            href = link.get("href")

            if not href:
                continue

            full_url = urljoin(
                BASE_URL,
                href
            )

            if full_url.startswith(BASE_URL):
                crawl(full_url)

    except Exception as e:

        print(
            f"[ERROR] {url} -> {e}"
        )

